<!-- ========== EVALUACIÓN DE BAJAS Y RESULTADOS (HIPOTÉTICO VS REAL) ========== -->
<section class="punto" id="evaluacion-bajas-rin">
    <h2>📊 Evaluación de Bajas y Resultados (Hipotético vs Real)</h2>
    <p style="margin-bottom: 20px; color: #1e293b; font-size: 15px;">
        Comparativa entre la estrategia real de Eisenhower (desviar al 7º Ejército hacia el Sarre) y la estrategia alternativa 
        propuesta por Devers (cruzar el Rin por Kehl y avanzar hacia Stuttgart).
    </p>

    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Aspecto</th>
                    <th>Estrategia Real (Eisenhower)</th>
                    <th>Estrategia Alternativa (Rin Sur)</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Bajas Aliadas</strong><br><span style="font-size:12px;color:#555;">(dic 1944 - may 1945)</span></td>
                    <td><span class="tag tag-red">80.000 – 100.000</span> muertos en las Ardenas, Alsacia y Sarre</td>
                    <td><span class="tag tag-green">Reducción estimada del 40-50%</span> al evitar la Bolsa de Colmar y las Ardenas</td>
                </tr>
                <tr>
                    <td><strong>Bajas Alemanas</strong></td>
                    <td><span class="tag tag-red">100.000</span> muertos y <span class="tag tag-yellow">300.000</span> prisioneros en el mismo periodo</td>
                    <td><span class="tag tag-yellow">Prisioneros masivos:</span> 200.000 – 300.000 al quedar atrapados sin suministros</td>
                </tr>
                <tr>
                    <td><strong>Duración de la Guerra</strong></td>
                    <td><span class="tag tag-yellow">Hasta mayo de 1945</span></td>
